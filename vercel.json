{
    "version": 2,
    "builds": [
        {
            "src": "api/wsgi.py",
            "use": "@vercel/python"
        },
        {
            "src": "build_files.sh",
            "use": "@vercel/static-build",
            "config": {
                "distDir": "staticfiles"
            }
        }
    ],
    "routes": [
        {
            "src": "/static/(.*)",
            "dest": "/static/$1"
        },
        {
            "src": "/(.*)",
            "dest": "api/wsgi.py"
        }
    ],
    "env": {
        "VERCEL_ENV": "production",
        "DJANGO_SETTINGS_MODULE": "api.settings",
        "MYSQL_DATABASE": "test",
        "MYSQL_USER": "3TJFdzBsW6BQcdA.root",
        "MYSQL_PASSWORD": "3xv6bY5a4oHNEUhh",
        "MYSQL_HOST": "gateway01.ap-northeast-1.prod.aws.tidbcloud.com",
        "MYSQL_PORT": "4000",
        "PYTHONPATH": "/var/task"
    }
}
